# Copia este archivo como ".env" y completa los valores para tu entorno local o de despliegue.

# Clave secreta de Django (genera una nueva para producción, nunca reutilices esta)
SECRET_KEY=django-insecure-CHANGE-ME

# Modo debug: True en desarrollo, False en producción
DEBUG=True

# Hosts permitidos, separados por coma
ALLOWED_HOSTS=127.0.0.1,localhost

# Cadena de conexión a la base de datos.
# Ejemplo local (SQLite, opcional, si se omite se usa SQLite por defecto):
# DATABASE_URL=sqlite:///db.sqlite3
# Ejemplo en producción (PostgreSQL / Render):
DATABASE_URL=postgres://usuario:password@host:5432/nombre_bd

# Zona horaria
TIME_ZONE=America/Guayaquil
